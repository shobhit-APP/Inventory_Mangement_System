# Ignore build artifacts and dependencies
target/
build/
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Maven specific files
.mvn/
!mvn/wrapper/maven-wrapper.jar

# IDE-specific files
### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### IntelliJ IDEA ###
.idea/
*.iws
*.iml
*.ipr

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

### VS Code ###
.vscode/

# OS-generated files
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp

# Exclude environment-specific configurations (uncomment if needed)
# .env
# application.properties
# application.yml

# Docker-related files
docker-compose.override.yml
.dockerignore

# Railway deployment specific exclusions
/node_modules/
/.railway/

# Exclude compiled files and dependency caches
*.class
*.jar
*.war
*.ear

# Ignore coverage reports
/coverage/
.nyc_output/

# Ignore local build and runtime files
/out/
/bin/
/gen/
/tmp/

# Ignore Git-related metadata
.git/
.gitignore.swp
